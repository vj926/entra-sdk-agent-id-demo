# Required runtime configuration. Copy to .env and fill in.
# These are read by app.py (FastAPI) at startup.

# Entra tenant where the Blueprint and Agent Identity live
TENANT_ID=

# The Blueprint's App (client) ID — the credential holder
BLUEPRINT_APP_ID=

# The Agent Identity's App (client) ID — credential-less child
AGENT_APP_ID=

# Where the auth-sidecar listens. In a single-pod deployment this is localhost.
SIDECAR_URL=http://localhost:5000
